            android:pathData="M 61,44 H 81 Q 93,44 93,54 Q 93,64 81,64 H 61 Q 49,64 49,54 Q 49,44 61,44 Z"/>
        <!-- Link 2 — main outline -->
        <path
            android:fillColor="#00000000"
